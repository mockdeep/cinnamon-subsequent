#!/usr/bin/env ruby
# frozen_string_literal: true

# Entry point for the Cinnamon todo sidebar.

# Locate our Gemfile regardless of the working directory, so the app can be
# launched from anywhere (e.g. an autostart .desktop entry).
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)

require "bundler/setup"
$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "config"
require "pid_file"
require "app"
require "sessions/watcher"
require "sessions/focus"

# Record this instance so `rake sidebar:*` can find it; clear on a clean exit
# (window close). A SIGTERM/kill leaves the file behind, but PidFile.running_pid
# treats a dead/reused pid as "not running" and clears it, so it self-heals.
PidFile.write
at_exit { PidFile.clear }

app = App.new(Config.load)
app.start
app.on_session_focus { |session_id| Sessions::Focus.call(session_id) }

# Continuously mirror Claude Code's session state into the footer dots. This is
# the only polling loop in the app; the Trello side stays manual-refresh.
watcher = Sessions::Watcher.new
watcher.on_change do |sessions, focused_xid|
  app.update_sessions(sessions, focused_xid)
end
watcher.start

Gtk.main
