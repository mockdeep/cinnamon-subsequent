source "https://rubygems.org"

# Native GTK3 bindings (ruby-gnome). Pulls in glib2, gobject-introspection,
# gdk3, cairo, pango, atk, gdk_pixbuf2 as dependencies.
gem "gtk3"

group :development, :test do
  gem "rake"
  gem "rspec"
  gem "rubocop"
  gem "rubocop-rake"
  gem "rubocop-rspec"
  gem "simplecov"
  gem "webmock"
end
